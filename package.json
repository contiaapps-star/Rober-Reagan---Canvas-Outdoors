{
  "name": "flowcore-marketing-sensor",
  "version": "0.1.0",
  "description": "FlowCore Marketing Sensor — daily competitive intelligence feed for FlowCore Water (Phase 0 skeleton).",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <21.0.0"
  },
  "scripts": {
    "dev": "concurrently -k -n css,server -c cyan,green \"npm:dev:css\" \"npm:dev:server\"",
    "dev:css": "tailwindcss -i ./src/styles.css -o ./public/css/output.css --watch",
    "dev:server": "tsx watch src/index.ts",
    "build": "npm run build:css && tsc && node scripts/copy-assets.mjs",
    "build:css": "tailwindcss -i ./src/styles.css -o ./public/css/output.css --minify",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "npm run build:css && npm run typecheck && vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "1.13.7",
    "better-sqlite3": "11.5.0",
    "drizzle-orm": "0.36.4",
    "fast-xml-parser": "4.5.0",
    "hono": "4.6.12",
    "pino": "9.5.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.12",
    "@types/node": "20.17.9",
    "@types/supertest": "6.0.2",
    "concurrently": "9.1.0",
    "drizzle-kit": "0.28.1",
    "happy-dom": "15.11.7",
    "msw": "2.6.6",
    "pino-pretty": "13.0.0",
    "supertest": "7.0.0",
    "tailwindcss": "3.4.15",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.6"
  }
}
