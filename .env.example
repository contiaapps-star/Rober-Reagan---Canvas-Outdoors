# ===== Core =====
# Node environment: development | production | test
NODE_ENV=development

# HTTP port the Hono server listens on
PORT=3000

# SQLite database path. In Docker this lives in the `db-data` volume.
# Use ":memory:" only for ephemeral test runs.
DATABASE_PATH=/data/app.db

# Operation mode: "demo" (fixtures) or "live" (real upstream APIs).
# Phase 0 only supports demo; live wiring lands in Phase 5.
OPERATION_MODE=demo

# ===== Secrets (REQUIRED — must be set, no defaults) =====
# Shared secret expected on POST /jobs/poll/:channel via X-Cron-Secret header.
CRON_SECRET=replace-me-with-a-long-random-string

# Secret used to sign session cookies. MUST be at least 32 characters.
SESSION_SECRET=replace-me-with-at-least-32-character-random-string

# ===== Budget guard =====
# Hard cap on monthly spend across paid APIs (Apify, ZenRows, Serper, DataForSEO, OpenRouter).
MONTHLY_BUDGET_USD=200

# Domain Rating threshold for new backlinks to count as a tracked event.
BACKLINK_DR_THRESHOLD=30

# ===== External integrations (optional in Phase 0; required only when OPERATION_MODE=live) =====
OPENROUTER_API_KEY=
APIFY_API_TOKEN=
ZENROWS_API_KEY=
YOUTUBE_API_KEY=
SERPER_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
